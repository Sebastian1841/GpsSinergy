{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test \"src/**/*.test.js\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css}\" \"*.{js,json,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,css}\" \"*.{js,json,html}\"",
    "validate": "npm test && npm run lint && npm run format:check && npm run build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "chart.js": "^4.5.1",
    "dompurify": "^3.4.11",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "vite": "^8.0.12",
    "vue-eslint-parser": "^10.4.0"
  }
}
